{
  "name": "yacht-ai-broker-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Yacht AI Broker Engine V1 - internal command center for a supervised digital yacht broker.",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch src/backend/server.ts",
    "dev:web": "vite --host 0.0.0.0 --port 5173",
    "build": "tsc -b && vite build",
    "start": "node dist/backend/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "lucide-react": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vite": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest"
  },
  "engines": {
    "node": ">=20"
  }
}
